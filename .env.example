# ─────────────────────────────────────────────────────────────────────────────
# Servidor Datos – Variables de entorno
# Copia este archivo a ".env" y rellena los valores reales.
# NUNCA subas ".env" a ningún repositorio de código.
# ─────────────────────────────────────────────────────────────────────────────

# Secreto de sesión: cadena aleatoria de al menos 32 caracteres.
# Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=CAMBIA_ESTO_POR_UNA_CADENA_ALEATORIA_LARGA_DE_AL_MENOS_32_CHARS

# Hash bcrypt de tu contraseña de acceso.
# Genera uno con: npm run gen-hash
PASSWORD_HASH=$2b$12$EJEMPLO_HASH_BCRYPT_SUSTITUYE_ESTO

# URL local donde escucha File Browser (no cambiar salvo configuración especial)
# Esta variable es opcional si no usas el proxy a File Browser.
FILEBROWSER_URL=http://127.0.0.1:8080

# Carpeta raíz que se servirá en el explorador integrado (/browse).
# Ruta absoluta al directorio que quieres compartir (p.ej. /home/usuario o /mnt/disco).
# Si no se define, se usa el directorio personal del usuario (HOME).
# DATA_ROOT=/home/usuario/Documentos

# Puerto en el que escucha este servidor Node.js
PORT=3000

# Entorno de ejecución. Usa "production" en producción real (activa cookies seguras).
# En desarrollo local sin HTTPS usa "development".
NODE_ENV=production
